<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <description>Record-triggered flow that publishes Application_Submitted__e platform event when a Loan Application Status changes to 'Submitted'. This routes the application to the Operations team queue.</description>
    <environments>Default</environments>
    <interviewLabel>Loan Application Submission Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Loan Application Submission Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <object>Loan_Application__c</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Submitted</stringValue>
            </value>
        </filters>
        <connector>
            <targetReference>Publish_Application_Submitted_Event</targetReference>
        </connector>
    </start>
    <actionCalls>
        <name>Publish_Application_Submitted_Event</name>
        <label>Publish Application Submitted Event</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <actionName>Application_Submitted__e</actionName>
        <actionType>eventCreation</actionType>
        <inputParameters>
            <name>Loan_Application_Id__c</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>Applicant_Name__c</name>
            <value>
                <elementReference>$Record.Applicant__r.Name</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>Loan_Amount__c</name>
            <value>
                <elementReference>$Record.Loan_Amount__c</elementReference>
            </value>
        </inputParameters>
    </actionCalls>
    <status>Active</status>
</Flow>
