<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <description>Record-triggered flow that publishes KYC_Completed__e platform event when KYC Request status transitions to 'Verified'. This triggers the Credit Assessment process.</description>
    <environments>Default</environments>
    <interviewLabel>KYC Completion Event Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>KYC Completion Event Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>
    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <object>KYC_Request__c</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
        <filterLogic>and</filterLogic>
        <filters>
            <field>KYC_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Verified</stringValue>
            </value>
        </filters>
        <connector>
            <targetReference>Publish_KYC_Completed_Event</targetReference>
        </connector>
    </start>
    <!-- Use recordCreates (Create Records) to publish a Platform Event — correct approach at API 59 -->
    <recordCreates>
        <name>Publish_KYC_Completed_Event</name>
        <label>Publish KYC Completed Event</label>
        <locationX>176</locationX>
        <locationY>134</locationY>
        <inputAssignments>
            <field>Loan_Application_Id__c</field>
            <value>
                <elementReference>$Record.Loan_Application__c</elementReference>
            </value>
        </inputAssignments>
        <object>KYC_Completed__e</object>
    </recordCreates>
</Flow>
