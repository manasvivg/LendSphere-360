<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightningCommunity__Page</target>
        <target>lightning__HomePage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage lightningCommunity__Page lightning__HomePage">
            <property name="defaultAmount"   type="Integer" label="Default Loan Amount"   default="1000000"/>
            <property name="defaultRate"     type="String"  label="Default Interest Rate" default="10.5"   />
            <property name="defaultTenure"   type="Integer" label="Default Tenure (Months)" default="120"  />
            <property name="showApplyButton" type="Boolean" label="Show Apply Button"     default="true"   />
        </targetConfig>
    </targetConfigs>
    <description>Real-time EMI calculator with sliders for loan amount, interest rate, and tenure. Displays monthly EMI, total interest, and a principal vs. interest donut chart.</description>
</LightningComponentBundle>
